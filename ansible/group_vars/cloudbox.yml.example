# Basic repo/deploy settings
remote_project_root: /opt/debian-system-image-provisioning
build_profile: server
build_host_overlay: cloudbox
cloudbox_bless_after_health: false

# User accounts baked into the image and provisioned on first boot.
cloudbox_users:
  - username: debian
    password: change-me-now
    can_login: true
    uid: host
    gid: host
    primary_group: host

# A/B slot device layout on the target host.
cloudbox_esp_part: /dev/disk/by-partlabel/ESP
cloudbox_slot_a_root: /dev/disk/by-partlabel/ROOT_A
cloudbox_slot_b_root: /dev/disk/by-partlabel/ROOT_B

# systemd-boot / boot-entry policy.
cloudbox_loader_timeout: 3
cloudbox_extra_kernel_args: "quiet console=ttyAMA0,115200 console=tty1"
cloudbox_auto_bless: true
cloudbox_reboot_on_health_failure: true
cloudbox_health_delay_secs: 30
cloudbox_health_failure_reboot_delay: 10
