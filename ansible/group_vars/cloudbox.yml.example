# Basic repo/deploy settings
remote_project_root: /opt/debian-system-image-provisioning
build_profile: server
build_host_overlay: cloudbox
cloudbox_update_reboot: true
cloudbox_bless_after_reboot: false

# User accounts baked into the image and provisioned on first boot.
cloudbox_users:
  - username: debian
    password: change-me-now
    can_login: true
    uid: host
    gid: host
    primary_group: host

# Host-specific boot flags rendered into the generated Boot Loader Specification entry.
cloudbox_extra_kernel_args: "quiet console=ttyAMA0,115200 console=tty1"

# One-time bootstrap mode:
# set this to a blank/offline target disk or raw image path for the first install.
# Leave it empty after the machine is already running the native sysupdate layout.
cloudbox_bootstrap_target: ""
cloudbox_loader_timeout: 3
cloudbox_esp_size: 512M
cloudbox_root_slot_size: 8G
