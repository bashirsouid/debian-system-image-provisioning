#!/usr/bin/env bash
#
# Description: Runs Kopia backups, auto-initializing/connecting repositories,
#              applying Ansible exclude settings, and alerting on status.
# Usage: kopia-backup-trigger [options] [<source> ...]
# Options:
#   -l, --limit-mb <int>     Upload limit in MiB (default: 100000)
#   -p, --parallel <int>     Number of parallel workers (default: 16)
#       --no-all             Do not include the --all flag (requires sources)
#       --snapshot-arg <x>   Additional argument forwarded to Kopia (repeatable)
#       --dry-run            Run Kopia in dry-run mode
#   -v, --verbose            Enable verbose logging
#   -s, --silent             Suppress informational output (errors only)
#   -h, --help               Display this help message and exit
# Environment:
#   KOPIA_BACKUP_TYPE        "s3" or "filesystem"
#   KOPIA_CONFIG_PATH        Configuration file path
#   KOPIA_CACHE_DIR          Cache directory path
#   KOPIA_FILESYSTEM_PATH    For simple filesystem backup (if destinations.json is not used)
#   KOPIA_UPLOAD_LIMIT_MB_DEFAULT   Override default upload limit
#   KOPIA_PARALLEL_DEFAULT          Override default parallelism

set -euo pipefail
IFS=$'\n\t'

readonly SCRIPT_NAME="$(basename "$0")"
readonly LOG_TIMESTAMP_FORMAT="%Y-%m-%dT%H:%M:%S%z"

UPLOAD_LIMIT_MB="${KOPIA_UPLOAD_LIMIT_MB_DEFAULT:-100000}"
PARALLEL_JOBS="${KOPIA_PARALLEL_DEFAULT:-16}"
INCLUDE_ALL=1
DRY_RUN=0
VERBOSE=0
SILENT=0

declare -a SNAPSHOT_ARGS=()
declare -a SOURCES=()
declare -a KOPIA_CMD=()

log_timestamp() {
  date +"${LOG_TIMESTAMP_FORMAT}"
}

log_info() {
  if [[ ${SILENT} -eq 0 ]]; then
    printf '[%s] [INFO] %s\n' "$(log_timestamp)" "$*" >&2
  fi
}

log_debug() {
  if [[ ${SILENT} -eq 0 && ${VERBOSE} -eq 1 ]]; then
    printf '[%s] [DEBUG] %s\n' "$(log_timestamp)" "$*" >&2
  fi
}

log_error() {
  printf '[%s] [ERROR] %s\n' "$(log_timestamp)" "$*" >&2
}

fail() {
  local code="$1"
  shift || true
  log_error "$*"
  exit "${code}"
}

handle_interrupt() {
  local signal="${1:-INT}"
  log_error "Received signal ${signal}. Aborting."
  exit 2
}

trap 'handle_interrupt INT' INT
trap 'handle_interrupt TERM' TERM

print_help() {
  cat <<EOF_HELP
${SCRIPT_NAME} - trigger Kopia snapshots with configurable settings and auto-setup.

Usage:
  ${SCRIPT_NAME} [options] [<source> ...]

Options:
  -l, --limit-mb <int>     Upload limit in MiB (default: ${UPLOAD_LIMIT_MB})
  -p, --parallel <int>     Parallel workers (default: ${PARALLEL_JOBS})
      --no-all             Do not include the --all flag (requires sources)
      --snapshot-arg <x>   Additional snapshot argument (repeatable)
      --dry-run            Run Kopia in dry-run mode
  -v, --verbose            Enable verbose logging
  -s, --silent             Suppress informational logging
  -h, --help               Show this help message
EOF_HELP
}

check_dependency() {
  local cmd="$1"
  local package="${2:-$1}"
  if ! command -v "${cmd}" >/dev/null 2>&1; then
    log_error "Required command '${cmd}' not found."
    log_error "Install on Debian/Ubuntu with: sudo apt install ${package}"
    exit 1
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -l|--limit-mb)
        if [[ $# -lt 2 ]]; then
          fail 2 "Missing value for --limit-mb option"
        fi
        UPLOAD_LIMIT_MB="$2"
        shift 2
        ;;
      -p|--parallel)
        if [[ $# -lt 2 ]]; then
          fail 2 "Missing value for --parallel option"
        fi
        PARALLEL_JOBS="$2"
        shift 2
        ;;
      --no-all)
        INCLUDE_ALL=0
        shift
        ;;
      --snapshot-arg)
        if [[ $# -lt 2 ]]; then
          fail 2 "Missing value for --snapshot-arg option"
        fi
        SNAPSHOT_ARGS+=("$2")
        shift 2
        ;;
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      -v|--verbose)
        VERBOSE=1
        shift
        ;;
      -s|--silent)
        SILENT=1
        shift
        ;;
      -h|--help)
        print_help
        exit 0
        ;;
      --)
        shift
        SOURCES+=("$@")
        break
        ;;
      -*)
        fail 2 "Unknown option: $1"
        ;;
      *)
        SOURCES+=("$1")
        shift
        ;;
    esac
  done
}

validate_configuration() {
  if ! [[ ${UPLOAD_LIMIT_MB} =~ ^[0-9]+$ ]]; then
    fail 1 "--limit-mb must be a positive integer."
  fi

  if ! [[ ${PARALLEL_JOBS} =~ ^[0-9]+$ ]]; then
    fail 1 "--parallel must be a positive integer."
  fi

  if [[ ${INCLUDE_ALL} -eq 0 && ${#SOURCES[@]} -eq 0 ]]; then
    fail 1 "Provide at least one source when --no-all is specified."
  fi
}

set_global_policies() {
  local config_path="$1"
  log_info "Applying Kopia global policies to ${config_path}..."
  
  # Set compression, throttle, retention
  kopia policy set --global --compression=zstd --config-file="${config_path}"
  kopia policy set --global --add-dot-ignore=nobackup --config-file="${config_path}"
  kopia policy set --global --keep-hourly=0 --keep-daily=90 --keep-weekly=0 --keep-monthly=0 --keep-annual=0 --config-file="${config_path}"

  # Extensive ignore list from Ansible defaults
  local excludes=(
    "Apps/"
    ".Trash/"
    ".Trash-1000/"
    "bin/"
    "models/"
    "snap/"
    "node_modules/"
    "node_repl_history"
    ".node_repl_history"
    "nobackup/"
    "NoBackup/"
    "lost+found/"
    ".vnc/"
    ".gconf/"
    ".local/"
    ".wine/"
    ".npm/"
    ".nvm/"
    ".config/"
    ".ansible/"
    ".var/"
    ".git/"
    ".pex/"
    ".swt/"
    ".java"
    ".rustup/"
    ".trash/"
    ".ssh/"
    ".dtrash/"
    "*.cache"
    "*.backup"
    "*.bak"
    "*.db"
    "*.orig"
    "*.save"
    ".viminfo"
    ".bash_history"
    ".zsh_history"
    ".ICEauthority"
    ".dosbox"
    ".netrc"
    ".mozilla"
    ".parsec"
    ".Xauthority"
    ".xsession-errors"
    ".pki"
    ".putty"
    ".kube"
    ".gnupg"
    ".zoom"
    ".zoom/"
    ".cloudflared"
    ".lesshst"
    ".x2go"
    ".steam"
    "SteamLibrary/"
    ".gnome"
    ".x2goclient"
    ".adobe"
    ".docker"
    ".dotnet"
    ".tig_history"
    ".python_history"
    ".android/adbkey"
    "Sim-bashirs"
    "anaconda/"
    "anaconda3/"
    "chess/"
    "*.cert"
    "*.key"
    "*.old"
    ".fltk"
    "ScummVM/"
    "Jts/"
    "GOG Games"
    "Virtualbox"
    "VirtualBox VMs"
    "Virtualization/"
  )

  # Apply the list of excludes in a single cmd invocation
  local cmd=("kopia" "policy" "set" "--global" "--config-file=${config_path}")
  local exclude
  for exclude in "${excludes[@]}"; do
    cmd+=("--add-ignore" "${exclude}")
  done
  "${cmd[@]}" >/dev/null 2>&1 || log_error "Failed to set some global ignore patterns."
}

# Run alerting notification
alert_status() {
  local status="$1" # "success" or "failure"
  local name="$2"
  local rc="${3:-0}"
  local service_name="${SYSTEMD_UNIT:-kopia-backup}"
  local creds_dir="${CREDENTIALS_DIRECTORY:-/etc/credstore}"
  
  if [[ "${status}" == "success" ]]; then
    log_info "Backup target [${name}] completed successfully."
    
    # Resolve ab-monitor alert
    if [[ -x "/usr/local/libexec/ab-monitor/notify.sh" ]]; then
      /usr/local/libexec/ab-monitor/notify.sh \
        --event resolve \
        --key "kopia_backup_${service_name}_${name}" \
        --severity "error" \
        --summary "Kopia backup target [${name}] for ${service_name} succeeded" || true
    fi
    
    # Ping healthchecks.io if url is provided
    if [[ -f "${creds_dir}/healthchecks-url" ]]; then
      local hc_url; hc_url="$(tr -d '\n' < "${creds_dir}/healthchecks-url")"
      if [[ -n "${hc_url}" ]]; then
        log_info "Pinging healthchecks.io success URL..."
        curl --silent --show-error --max-time 10 \
          --retry 3 --retry-delay 5 --retry-connrefused \
          --output /dev/null "${hc_url}" || true
      fi
    fi
  else
    log_error "Backup target [${name}] failed with code ${rc}."
    
    # Fire ab-monitor failure alert
    if [[ -x "/usr/local/libexec/ab-monitor/ad-hoc-alert.sh" ]]; then
      /usr/local/libexec/ab-monitor/ad-hoc-alert.sh \
        "kopia_backup_${service_name}_${name}" \
        "error" \
        "Kopia backup target [${name}] for ${service_name} failed" \
        "{\"exit_code\": ${rc}}" || true
    fi
    
    # Ping healthchecks.io failure URL
    if [[ -f "${creds_dir}/healthchecks-url" ]]; then
      local hc_url; hc_url="$(tr -d '\n' < "${creds_dir}/healthchecks-url")"
      if [[ -n "${hc_url}" ]]; then
        log_info "Pinging healthchecks.io failure URL..."
        curl --silent --show-error --max-time 10 \
          --retry 3 --retry-delay 5 --retry-connrefused \
          --output /dev/null "${hc_url}/fail" || true
      fi
    fi
  fi
}

run_s3_backup() {
  local config_path="${KOPIA_CONFIG_PATH:-/var/lib/kopia/cloud.config}"
  local cache_dir="${KOPIA_CACHE_DIR:-/var/cache/kopia/cloud}"
  local creds_dir="${CREDENTIALS_DIRECTORY:-/etc/credstore}"
  local s3_json="${creds_dir}/s3-creds"
  
  if [[ ! -f "${s3_json}" ]]; then
    fail 1 "S3 credentials missing from ${s3_json}"
  fi
  
  local endpoint bucket access_key secret_key
  endpoint="$(jq -r '.endpoint // "https://s3.amazonaws.com"' "${s3_json}")"
  bucket="$(jq -r '.bucket // empty' "${s3_json}")"
  access_key="$(jq -r '.accessKeyId // empty' "${s3_json}")"
  secret_key="$(jq -r '.secretAccessKey // empty' "${s3_json}")"
  
  if [[ -z "${bucket}" || -z "${access_key}" || -z "${secret_key}" ]]; then
    fail 1 "S3 credentials missing required fields (bucket, accessKeyId, secretAccessKey)"
  fi
  
  export AWS_ACCESS_KEY_ID="${access_key}"
  export AWS_SECRET_ACCESS_KEY="${secret_key}"
  
  # Load password
  if [[ -f "${creds_dir}/kopia-password" ]]; then
    export KOPIA_PASSWORD
    KOPIA_PASSWORD="$(tr -d '\n' < "${creds_dir}/kopia-password")"
  fi
  
  log_info "Checking Kopia S3 repository status..."
  if ! kopia repository status --config-file="${config_path}" >/dev/null 2>&1; then
    log_info "Connecting to S3 repository in bucket ${bucket}..."
    if ! kopia repository connect s3 \
      --config-file="${config_path}" \
      --cache-directory="${cache_dir}" \
      --bucket="${bucket}" \
      --endpoint="${endpoint}" >/dev/null 2>&1; then
      
      log_info "Connection failed. Initializing new S3 repository..."
      kopia repository create s3 \
        --config-file="${config_path}" \
        --cache-directory="${cache_dir}" \
        --bucket="${bucket}" \
        --endpoint="${endpoint}"
    fi
  fi
  
  set_global_policies "${config_path}"
  
  # Run the snapshot
  local rc=0
  local cmd=("kopia" "snapshot" "create" "--config-file=${config_path}" "--upload-limit-mb=${UPLOAD_LIMIT_MB}" "--parallel=${PARALLEL_JOBS}")
  if [[ ${DRY_RUN} -eq 1 ]]; then cmd+=("--dry-run"); fi
  if [[ ${#SNAPSHOT_ARGS[@]} -gt 0 ]]; then cmd+=("${SNAPSHOT_ARGS[@]}"); fi
  if [[ ${INCLUDE_ALL} -eq 1 ]]; then cmd+=("--all"); fi
  if [[ ${#SOURCES[@]} -gt 0 ]]; then cmd+=("${SOURCES[@]}"); fi
  
  log_info "Executing Kopia S3 snapshot..."
  if [[ ${SILENT} -eq 1 ]]; then
    "${cmd[@]}" >/dev/null || rc=$?
  else
    "${cmd[@]}" || rc=$?
  fi
  
  if [[ ${rc} -eq 0 ]]; then
    alert_status "success" "s3"
  else
    alert_status "failure" "s3" "${rc}"
    exit "${rc}"
  fi
}

run_filesystem_backup() {
  local destinations_file="/etc/kopia-backup-destinations.json"
  local creds_dir="${CREDENTIALS_DIRECTORY:-/etc/credstore}"
  
  if [[ ! -f "${destinations_file}" ]]; then
    # Fallback to simple filesystem path from environment
    if [[ -n "${KOPIA_FILESYSTEM_PATH:-}" ]]; then
      run_single_filesystem_backup "default" "${KOPIA_FILESYSTEM_PATH}" "" "true" ""
      return 0
    else
      log_info "No destinations JSON file at ${destinations_file} and no KOPIA_FILESYSTEM_PATH. Nothing to backup."
      exit 0
    fi
  fi
  
  local dests_count; dests_count="$(jq 'length' "${destinations_file}")"
  if [[ "${dests_count}" -eq 0 ]]; then
    log_info "No backup destinations declared in ${destinations_file}."
    exit 0
  fi
  
  local overall_success=true
  local idx
  for idx in $(seq 0 $((dests_count - 1))); do
    local entry; entry="$(jq -c ".[${idx}]" "${destinations_file}")"
    local name; name="$(jq -r '.name // empty' <<<"${entry}")"
    local path; path="$(jq -r '.path // empty' <<<"${entry}")"
    local precondition; precondition="$(jq -r '.precondition // empty' <<<"${entry}")"
    local cache; cache="$(jq -r '.cache // empty' <<<"${entry}")"
    local config; config="$(jq -r '.config // empty' <<<"${entry}")"
    local additional_excludes; additional_excludes="$(jq -rc '.additionalExcludes // empty' <<<"${entry}")"
    
    # Run precondition if specified
    if [[ -n "${precondition}" ]]; then
      log_info "Checking precondition for ${name}: ${precondition}"
      if ! eval "${precondition}"; then
        log_info "Precondition failed for ${name}. Skipping."
        continue
      fi
    fi
    
    # Load destination specific passcode or fallback
    local pass_secret="kopia-password-${name}"
    local pass_val=""
    if [[ -f "${creds_dir}/${pass_secret}" ]]; then
      pass_val="$(tr -d '\n' < "${creds_dir}/${pass_secret}")"
    elif [[ -f "${creds_dir}/kopia-password" ]]; then
      pass_val="$(tr -d '\n' < "${creds_dir}/kopia-password")"
    fi
    
    if ! run_single_filesystem_backup "${name}" "${path}" "${pass_val}" "false" "${config}" "${cache}" "${additional_excludes}"; then
      overall_success=false
    fi
  done
  
  if [[ "${overall_success}" != "true" ]]; then
    fail 1 "One or more filesystem backups failed."
  fi
}

run_single_filesystem_backup() {
  local name="$1"
  local path="$2"
  local password="$3"
  # $4 (fallback_mode) reserved for future use
  local config="$5"
  local cache="$6"
  local additional_excludes="$7"
  
  local config_path="${config}"
  if [[ -z "${config_path}" ]]; then
    config_path="/var/lib/kopia/repository.${name}.config"
  fi
  
  local cache_dir="${cache}"
  if [[ -z "${cache_dir}" ]]; then
    cache_dir="/var/cache/kopia/${name}"
  fi
  
  mkdir -p "$(dirname "${config_path}")"
  mkdir -p "${cache_dir}"
  mkdir -p "${path}"
  
  export KOPIA_PASSWORD="${password}"
  
  log_info "Checking Kopia repository status at ${path}..."
  if ! kopia repository status --config-file="${config_path}" >/dev/null 2>&1; then
    log_info "Connecting to filesystem repository at ${path}..."
    if ! kopia repository connect filesystem \
      --config-file="${config_path}" \
      --cache-directory="${cache_dir}" \
      --path="${path}" >/dev/null 2>&1; then
      
      log_info "Connection failed. Initializing filesystem repository at ${path}..."
      kopia repository create filesystem \
        --config-file="${config_path}" \
        --cache-directory="${cache_dir}" \
        --path="${path}"
    fi
  fi
  
  set_global_policies "${config_path}"
  
  # Apply additional excludes if present
  if [[ -n "${additional_excludes}" && "${additional_excludes}" != "null" ]]; then
    log_info "Applying additional excludes for target ${name}..."
    local excludes_arr; mapfile -t excludes_arr < <(jq -r '.[]' <<<"${additional_excludes}")
    local exclude
    for exclude in "${excludes_arr[@]}"; do
      kopia policy set --global --config-file="${config_path}" --add-ignore "${exclude}" >/dev/null 2>&1 || true
    done
  fi
  
  # Run the snapshot
  local rc=0
  local cmd=("kopia" "snapshot" "create" "--config-file=${config_path}" "--upload-limit-mb=${UPLOAD_LIMIT_MB}" "--parallel=${PARALLEL_JOBS}")
  if [[ ${DRY_RUN} -eq 1 ]]; then cmd+=("--dry-run"); fi
  if [[ ${#SNAPSHOT_ARGS[@]} -gt 0 ]]; then cmd+=("${SNAPSHOT_ARGS[@]}"); fi
  if [[ ${INCLUDE_ALL} -eq 1 ]]; then cmd+=("--all"); fi
  if [[ ${#SOURCES[@]} -gt 0 ]]; then cmd+=("${SOURCES[@]}"); fi
  
  log_info "Executing Kopia snapshot for filesystem target [${name}]..."
  if [[ ${SILENT} -eq 1 ]]; then
    "${cmd[@]}" >/dev/null || rc=$?
  else
    "${cmd[@]}" || rc=$?
  fi
  
  if [[ ${rc} -eq 0 ]]; then
    alert_status "success" "${name}"
    return 0
  else
    alert_status "failure" "${name}" "${rc}"
    return 1
  fi
}

main() {
  parse_args "$@"
  check_dependency "kopia"
  check_dependency "jq"
  validate_configuration
  
  # Determine backup type and run
  local type="${KOPIA_BACKUP_TYPE:-}"
  if [[ -z "${type}" ]]; then
    # Legacy/Default behavior (no auto-setup, just run snapshot)
    log_info "KOPIA_BACKUP_TYPE not specified. Running snapshot with default config..."
    
    # Load password from environment/credentials if available
    local creds_dir="${CREDENTIALS_DIRECTORY:-/etc/credstore}"
    if [[ -f "${creds_dir}/kopia-password" ]]; then
      export KOPIA_PASSWORD
      KOPIA_PASSWORD="$(tr -d '\n' < "${creds_dir}/kopia-password")"
    fi
    
    build_command
    run_kopia
  elif [[ "${type}" == "s3" ]]; then
    run_s3_backup
  elif [[ "${type}" == "filesystem" ]]; then
    run_filesystem_backup
  else
    fail 1 "Unknown KOPIA_BACKUP_TYPE: ${type}"
  fi
}

# Original legacy run commands for compatibility
build_command() {
  KOPIA_CMD=("kopia" "snapshot" "create" "--upload-limit-mb=${UPLOAD_LIMIT_MB}" "--parallel=${PARALLEL_JOBS}")
  if [[ ${DRY_RUN} -eq 1 ]]; then KOPIA_CMD+=("--dry-run"); fi
  if [[ ${#SNAPSHOT_ARGS[@]} -gt 0 ]]; then KOPIA_CMD+=("${SNAPSHOT_ARGS[@]}"); fi
  if [[ ${INCLUDE_ALL} -eq 1 ]]; then KOPIA_CMD+=("--all"); fi
  if [[ ${#SOURCES[@]} -gt 0 ]]; then KOPIA_CMD+=("${SOURCES[@]}"); fi
}

run_kopia() {
  local rc=0
  if [[ ${SILENT} -eq 1 ]]; then
    "${KOPIA_CMD[@]}" >/dev/null || rc=$?
  else
    "${KOPIA_CMD[@]}" || rc=$?
  fi
  
  if [[ ${rc} -eq 0 ]]; then
    alert_status "success" "default"
  else
    alert_status "failure" "default" "${rc}"
    exit "${rc}"
  fi
}

main "$@"
