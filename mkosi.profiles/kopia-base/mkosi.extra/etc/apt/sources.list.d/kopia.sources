Types: deb
# Kopia's official APT repo. Host is packages.kopia.io (NOT pkg.kopia.io,
# which does not resolve) and it is a standard suite repo (stable main),
# not a flat repo. See https://kopia.io/docs/installation/.
URIs: https://packages.kopia.io/apt/
Suites: stable
Components: main
Architectures: amd64
Signed-By: /etc/apt/keyrings/kopia.gpg
