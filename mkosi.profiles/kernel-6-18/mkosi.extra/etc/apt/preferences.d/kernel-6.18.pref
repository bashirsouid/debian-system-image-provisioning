# Pull Linux kernel 6.18 packages from trixie-backports.
# This ensures the 6.18 kernel and headers are installed instead of
# the default trixie kernel when this profile is selected.
Package: linux-image-6.18*
Pin: release a=trixie-backports
Pin-Priority: 600

Package: linux-headers-6.18*
Pin: release a=trixie-backports
Pin-Priority: 600

# Pull all non‑free firmware from backports when using kernel‑6‑18
Package: firmware-*
Pin: release a=trixie-backports
Pin-Priority: 600