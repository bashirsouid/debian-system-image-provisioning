# Lets a regular (non-root) user launch X via startx / xinit. Without
# both of these lines, Xorg refuses to open /dev/tty1 (owned root:root,
# mode 0600) and `startx` dies with:
#   xf86OpenConsole: Cannot open virtual console 1 (Permission denied)
# That failure happens even when the user is in the tty / video / input
# groups — the group bits alone don't grant tty1 write access because
# tty1 is NOT group-owned by tty before login. The setuid Xorg.wrap
# binary shipped by xserver-xorg-legacy IS what bridges this gap, but
# only if the config below opts into it.
allowed_users=anybody
needs_root_rights=yes
