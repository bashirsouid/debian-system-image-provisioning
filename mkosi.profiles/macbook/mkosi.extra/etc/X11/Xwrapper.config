# Xwrapper.config(5) — read by /usr/lib/xorg/Xorg.wrap from
# the xserver-xorg-legacy package. Lets any logged-in user run
# `startx` and have Xorg open the active VT as root, which is
# what's needed on hardware where the kernel won't let a normal
# user KDSETMODE on /dev/ttyN.
#
# `allowed_users=anybody` means startx works even after `su` to
# another user (handy on this hardware-test image where root
# logs in on tty1 and then drops to a regular user with `su`).
# `needs_root_rights=yes` makes the wrapper actually run Xorg
# with the elevated capabilities that `xf86OpenConsole` needs
# instead of the wrapper's default `auto` (which would refuse
# in this scenario).
allowed_users=anybody
needs_root_rights=yes
