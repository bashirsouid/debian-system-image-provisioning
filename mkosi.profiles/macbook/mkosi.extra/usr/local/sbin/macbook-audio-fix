#!/usr/bin/env bash
set -euo pipefail

if [[ $EUID -ne 0 ]]; then
    exec sudo "$0" "$@"
fi

kernel="$(uname -r)"
module_name="snd_hda_macbookpro"
module_version="0.1"
source_dir="/usr/local/src/snd_hda_macbookpro"
dkms_src="/usr/src/${module_name}-${module_version}"

if [[ ! -d "$source_dir" || ! -f "$source_dir/install.cirrus.driver.sh" ]]; then
    echo "ERROR: bundled snd_hda_macbookpro source not found at $source_dir" >&2
    exit 1
fi

find_cs8409_override_module() {
    local kernel="$1"
    local path=""

    path="$(find "/lib/modules/$kernel/updates" -type f -name 'snd-hda-codec-cs8409.ko*' -print 2>/dev/null | sort | head -n1 || true)"
    if [[ -n "$path" ]]; then
        printf '%s\n' "$path"
        return 0
    fi

    path="$(modinfo -k "$kernel" -F filename snd_hda_codec_cs8409 2>/dev/null || true)"
    if [[ "$path" == /lib/modules/"$kernel"/updates/* ]]; then
        printf '%s\n' "$path"
        return 0
    fi

    return 1
}

patch_driver_tree() {
    local tree="$1"

    {
        while IFS= read -r line; do
            if [[ "$line" == 'UNAME=${1:-$(uname -r)}' ]]; then
                printf '%s\n' 'if [[ -z "${UNAME:-}" ]]; then'
                printf '%s\n' '    UNAME=${1:-$(uname -r)}'
                printf '%s\n' 'fi'
            else
                printf '%s\n' "$line"
            fi
        done < "$tree/install.cirrus.driver.sh"
    } > "$tree/install.cirrus.driver.sh.tmp"
    mv "$tree/install.cirrus.driver.sh.tmp" "$tree/install.cirrus.driver.sh"

    cat > "$tree/dkms.conf" <<EOF2
PACKAGE_NAME="$module_name"
PACKAGE_VERSION="$module_version"
PRE_BUILD="install.cirrus.driver.sh -k \$kernelver --dkms"
MAKE="make KERNELRELEASE=\${kernelver} KDIR=/lib/modules/\${kernelver}/build M=\${dkms_tree}/\${PACKAGE_NAME}/\${PACKAGE_VERSION}/build/build/hda CFLAGS_MODULE='-DAPPLE_PINSENSE_FIXUP -DAPPLE_CODECS -DCONFIG_SND_HDA_RECONFIG=1 -Wno-unused-variable -Wno-unused-function -Wno-error -Wno-incompatible-pointer-types'"
BUILT_MODULE_NAME[0]="snd-hda-codec-cs8409"
BUILT_MODULE_LOCATION[0]="build/hda/codecs/cirrus"
DEST_MODULE_LOCATION[0]="/updates/codecs/cirrus"
AUTOINSTALL="yes"
EOF2

    chmod +x "$tree/install.cirrus.driver.sh"
}

apt-get update
DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    dkms build-essential patch wget openssl ca-certificates xz-utils \
    "linux-headers-$kernel"

rm -rf "$dkms_src"
mkdir -p "$dkms_src"
cp -a "$source_dir/." "$dkms_src/"
patch_driver_tree "$dkms_src"

pushd "$dkms_src" >/dev/null

dkms remove -m "$module_name" -v "$module_version" --all >/dev/null 2>&1 || true
dkms add -m "$module_name" -v "$module_version"
dkms build -m "$module_name" -v "$module_version" -k "$kernel" --force
dkms install -m "$module_name" -v "$module_version" -k "$kernel" --force

popd >/dev/null

depmod -a

echo
find_cs8409_override_module "$kernel" || modinfo -k "$kernel" -F filename snd_hda_codec_cs8409 2>/dev/null || true
echo
echo "If sound is still missing immediately after this run, reboot once and test with:"
echo "  speaker-test -t wav -l 1"
