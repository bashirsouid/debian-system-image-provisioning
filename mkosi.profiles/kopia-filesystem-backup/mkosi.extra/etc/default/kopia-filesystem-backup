# /etc/default/kopia-filesystem-backup
# Tunables for the hourly encrypted Kopia filesystem backup.
# Which drives get backed up is defined by the host's kopia_filesystem_targets
# descriptor list (rendered to /etc/kopia/targets.json), not here. Unmounted
# drives are skipped automatically.

# Upload throttle and parallelism for `kopia snapshot create`.
KOPIA_UPLOAD_LIMIT_MB_DEFAULT=50000
KOPIA_PARALLEL_DEFAULT=16

# Cache caps (per repository) so a restore/verify can never fill the disk.
# Defaults live in the scripts; uncomment to override.
#KOPIA_CONTENT_CACHE_MB=1000
#KOPIA_METADATA_CACHE_MB=500
