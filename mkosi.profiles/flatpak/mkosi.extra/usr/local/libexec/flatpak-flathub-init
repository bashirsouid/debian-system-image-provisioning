#!/usr/bin/env bash
set -euo pipefail

MARKER="/var/lib/flatpak/.ab-flathub-added"
REMOTE_URL="https://dl.flathub.org/repo/flathub.flatpakrepo"

[[ -e "$MARKER" ]] && exit 0
[[ -d /var/lib/flatpak ]] || exit 0

if ! getent ahosts dl.flathub.org >/dev/null 2>&1; then
    echo "Flathub DNS not available yet; will retry later."
    exit 0
fi

if flatpak remote-add --if-not-exists flathub "$REMOTE_URL"; then
    install -m 0644 /dev/null "$MARKER"
else
    echo "Flathub remote setup failed; will retry later."
fi
