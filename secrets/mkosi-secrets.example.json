{
  "ssh-authorized-keys": "ssh-ed25519 AAAA... hardware-key\n",
  "tailscale-authkey": "tskey-auth-...",
  "cloudflared-token": "eyJhIjoi...",
  "mailjet_public_key": "0123456789abcdef0123456789abcdef",
  "mailjet_private_key": "0123456789abcdef0123456789abcdef",
  "pagerduty-routing-key": "0123456789abcdef0123456789abcdef",
  "healthchecks-ping-url": "https://hc-ping.com/...",
  "wifi-ssid": "example-ssid",
  "wifi-psk": "example-passphrase",
  "s3-backup-credentials.json": {
    "endpoint": "",
    "accessKeyId": "YOUR_ACCESS_KEY",
    "secretAccessKey": "YOUR_SECRET_KEY",
    "bucket": "your-backup-bucket"
  },
  "users.json": [
    {
      "username": "yourname",
      "comment": "Primary login user",
      "can_login": true,
      "uid": 1000,
      "gid": 1000,
      "primary_group": "yourname",
      "groups": ["sudo", "audio", "video", "render", "input", "tty", "plugdev", "dialout", "netdev"],
      "shell": "/bin/bash",
      "password_hash": "$y$j9T$REPLACE_WITH_OUTPUT_OF_bin/hash-password.sh"
    }
  ],
  "hosts": {
    "example-host": {
      "tailscale-authkey": "tskey-auth-host-specific-...",
      "users.json": [
        {
          "username": "yourname",
          "comment": "Primary login user — host-specific password",
          "can_login": true,
          "uid": 1000,
          "gid": 1000,
          "primary_group": "yourname",
          "groups": ["sudo", "audio", "video", "render", "input", "tty", "plugdev", "dialout", "netdev"],
          "shell": "/bin/bash",
          "password_hash": "$y$j9T$REPLACE_WITH_HOST_SPECIFIC_HASH"
        }
      ]
    }
  }
}
