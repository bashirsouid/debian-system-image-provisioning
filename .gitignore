# Secure Boot signing keys (generated by
# bin/generate-secureboot-keys.sh). The public cert and enrollment
# blobs are also here; keep them local unless you have a clear reason
# to publish them. The private key MUST NEVER be committed; losing it
# means re-enrolling every already-provisioned machine.
.secureboot/

# Secrets & credentials
.users.json
.mkosi-secrets/
!.mkosi-secrets.example/
!.mkosi-secrets.example/**
secrets/*.json
!secrets/*.json.age
!secrets/*.json.age.conf
!secrets/*.json.age.recipients
!secrets/*.example.json

# Ansible vault
.vault_pass
.vault_pass.*

# Host instance descriptors (plaintext, non-secret, but personal — they
# name your machines/profiles/backup paths). Committed template lives in
# hosts.local.example/. .mkosi-host/ is the synthetic overlay build.sh
# renders from a descriptor at build time.
/hosts.local/
!/hosts.local.example/
!/hosts.local.example/**
.mkosi-host/

# Build outputs & cache
mkosi.cache/
mkosi.pkgcache/
mkosi.builddir/
mkosi.workspace/
mkosi.tmp/
mkosi.output/
image
image.*
.config-checksum
.config-version
.mkosi-metadata/
.mkosi-thirdparty/

# Editor / tooling scratch
*.bak
*.bak.*
*.orig
*~
.DS_Store
opencode.json

# Legacy
.build/
artifacts/
third-party/
.mkosi-private/
*.patch

# Large binary files
*.deb

# Local machine and deployment state
ab-flash.conf
ansible/inventory.ini
ansible/group_vars/cloudbox.yml

# Generated by scripts/package-credentials.sh during build.
# These contain build credential staging material. They MUST NOT be committed.
mkosi.extra/etc/credstore/
mkosi.extra/etc/credstore.encrypted/
mkosi.extra/etc/ssh/authorized_keys.d/
mkosi.extra/var/lib/systemd/credential.secret

# Generated by scripts/fetch-third-party-keys.sh. Keyrings are binary
# and rotate; let update-3rd-party-deps.sh fetch them fresh.
mkosi.extra/etc/apt/keyrings/*.gpg
mkosi.extra/etc/apt/keyrings/*.asc
!mkosi.extra/etc/apt/keyrings/README.md

# Live-USB staging area used by scripts/usb-write-and-verify.sh
.live-usb-stage/

# Local lint/test scratch
.shellcheck-cache/

tmp/
