# Secrets & credentials
.users.json
.env
.mkosi-secrets/
!.mkosi-secrets.example/
!.mkosi-secrets.example/**

# Ansible vault
.vault_pass
.vault_pass.*

# Build outputs & cache
mkosi.cache/
mkosi.builddir/
mkosi.output/
image
image.*
.config-checksum

# Legacy
.build/
artifacts/
third-party/
.mkosi-private/
*.patch

# Local machine and deployment state
ab-flash.conf
ansible/inventory.ini
ansible/group_vars/cloudbox.yml

# Generated by scripts/package-credentials.sh during build.
# These contain per-build encrypted credential blobs and the per-image
# credential.secret key material. They MUST NOT be committed.
mkosi.extra/etc/credstore.encrypted/
mkosi.extra/etc/ssh/authorized_keys.d/
mkosi.extra/var/lib/systemd/credential.secret

# Generated by scripts/fetch-third-party-keys.sh. Keyrings are binary
# and rotate; let update-3rd-party-deps.sh fetch them fresh.
mkosi.extra/etc/apt/keyrings/*.gpg
mkosi.extra/etc/apt/keyrings/*.asc
!mkosi.extra/etc/apt/keyrings/README.md

# Live-USB staging area used by scripts/usb-write-and-verify.sh
.live-usb-stage/

# Local lint/test scratch
.shellcheck-cache/

