#!/usr/bin/env bash
set -euo pipefail

ROOT="${BUILDROOT:?BUILDROOT is required}"
UNIT_LINK_DIR="$ROOT/etc/systemd/system/multi-user.target.wants"
UNIT_TARGET="/usr/lib/systemd/system/provision-local-users.service"
UNIT_LINK="$UNIT_LINK_DIR/provision-local-users.service"

echo "==> [FINALIZE] no host-side account provisioning; users will be created on first boot"
mkdir -p "$UNIT_LINK_DIR"
ln -snf "$UNIT_TARGET" "$UNIT_LINK"
