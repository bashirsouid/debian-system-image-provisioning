[
  {
    "_notes": [
      "Copy this file to .users.json and edit before running ./build.sh.",
      "",
      "Password options, in order of precedence:",
      "  1. 'password_hash' — a pre-hashed crypt string. Generate one with:",
      "        ./bin/hash-password.sh --hash-only",
      "     A password_hash of '!' or '*' means the account is LOCKED and",
      "     no login is possible. That is a lock marker, not a real hash.",
      "  2. 'password' — plaintext; build.sh hashes it at build time.",
      "     Convenient for throwaway test builds, not recommended for",
      "     machines you actually trust.",
      "",
      "If 'can_login' is false or no usable password is set, the account is",
      "locked and first-boot provisioning calls 'usermod -L'.",
      "",
      "For per-host overrides, create hosts/<name>/users.json with the same",
      "shape — it takes precedence over this file when you build with",
      "--host <name>.",
      "",
      "Fields that are understood:",
      "  username              required. 'root' is normally locked but can be",
      "                        temporarily enabled via ./build.sh --allow-root (which",
      "                        sets the password to 'llama').",
      "",
      "  can_login             default true; false => system/service account",
      "  uid, gid              optional; default is auto-assigned. May be 'host'",
      "                        to copy the build host's value, useful for the",
      "                        user whose host files get mounted via RuntimeHome",
      "  primary_group         default: same as username. May be 'host'",
      "  groups                supplementary groups, array of names",
      "  shell                 default /bin/bash for login users",
      "  home                  default /home/<username>",
      "  password              plaintext, will be hashed at build time",
      "  password_hash         pre-hashed crypt string (wins over 'password')",
      "  ssh_authorized_keys_file  path relative to repo root to install into",
      "                            ~/.ssh/authorized_keys on first boot",
      "  dotfiles_repo         git URL or path (relative to repo root, or",
      "                            absolute) of a dotfiles repo to bake into",
      "                            the image. Cloned with submodules at build",
      "                            time on the build host; ~/.dotfiles is",
      "                            populated on first boot before login. The",
      "                            clone is cached at ~/.cache/mkosi-dotfiles",
      "                            so repeat builds only do `git fetch`.",
      "  dotfiles_install      shell command run from inside ~/.dotfiles on",
      "                            first boot to apply the dotfiles. Defaults",
      "                            to './install' (the dotbot convention).",
      "                            Override when your repo names its bootstrap",
      "                            script differently or needs flags, e.g.",
      "                            './install_packages.sh --skip-submodule-update'",
      "                            (use --skip-submodule-update if your script",
      "                            would otherwise try to fetch submodules over",
      "                            the network — first boot is often offline).",
      "",
      "Any field beginning with '_' (like this one) is ignored by the build."
    ]
  },
  {
    "username": "demo",
    "comment": "Primary login user",
    "can_login": true,
    "uid": 1000,
    "gid": 1000,
    "primary_group": "demo",
    "_groups_notes": [
      "tty: needed for X (open /dev/tty[1-12]) when xserver-xorg-legacy",
      "     wraps Xorg with allowed_users=anybody.",
      "audio/video/render/input: device access for desktop apps.",
      "plugdev/dialout: USB / serial peripherals.",
      "sudo: ability to run privileged commands.",
      "netdev: NetworkManager / iwd connection management."
    ],
    "groups": ["sudo", "audio", "video", "render", "input", "tty", "plugdev", "dialout", "netdev"],
    "shell": "/bin/bash",
    "password": "change-me-now",
    "force_password_change_on_first_login": false,
    "ssh_authorized_keys_file": ".mkosi-secrets/ssh-authorized-keys",
    "_dotfiles_example": [
      "Drop the leading underscore on the two fields below to bake a dotfiles",
      "repo into the image and apply it on first boot. The repo is cloned with",
      "submodules at build time, so first boot needs no network access. Use",
      "your fork's https or ssh URL, or a local path like '../dotfiles' that's",
      "resolved relative to this repo's root."
    ],
    "_dotfiles_repo": "https://github.com/yourname/dotfiles.git",
    "_dotfiles_install": "./install"
  }
  /*
  ,
  {
    "username": "root",
    "comment": "Root login (only works if build.sh --allow-root is used)",
    "can_login": true,
    "password": "rootroot"
  }
  */
]
