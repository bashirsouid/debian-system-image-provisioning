[Transfer]
ProtectVersion=%A

[Source]
Type=regular-file
Path=/
PathRelativeTo=explicit
MatchPattern=debian-provisioning-devbox_@v_%a.root.raw

[Target]
Type=partition
Path=auto
MatchPattern=debian-provisioning-devbox_@v
MatchPartitionType=root
PartitionGrowFileSystem=yes
ReadOnly=no
InstancesMax=2
