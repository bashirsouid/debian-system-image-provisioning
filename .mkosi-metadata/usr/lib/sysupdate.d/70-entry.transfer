[Transfer]
ProtectVersion=%A

[Source]
Type=regular-file
Path=/
PathRelativeTo=explicit
MatchPattern=debian-provisioning-devbox_@v_%a.conf

[Target]
Type=regular-file
Path=/loader/entries
PathRelativeTo=boot
MatchPattern=debian-provisioning-devbox_@v_%a+@l-@d.conf \
             debian-provisioning-devbox_@v_%a.conf
Mode=0644
TriesLeft=3
TriesDone=0
InstancesMax=2
