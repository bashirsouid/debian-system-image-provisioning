# Example evox2-oriented A/B deployment config.
#
# Replace these with the real stable by-partlabel/by-partuuid symlinks from the
# machine before using scripts/ab-flash.sh.

ESP_PART=/dev/disk/by-partlabel/ESP
SLOT_A_ROOT=/dev/disk/by-partlabel/ROOT_A
SLOT_B_ROOT=/dev/disk/by-partlabel/ROOT_B

AB_BOOTLOADER=systemd-boot
INSTALL_SYSTEMD_BOOT=yes
LOADER_TIMEOUT=5

AB_AUTO_BLESS=no
AB_HEALTH_DELAY_SECS=20
AB_HEALTH_HOOK_DIR=/usr/local/libexec/ab-health-check.d
AB_REBOOT_ON_HEALTH_FAILURE=no
AB_HEALTH_FAILURE_REBOOT_DELAY=5

# Replace the amdgpu.gttsize value with the exact value you want for this host.
EXTRA_KERNEL_ARGS="quiet amdgpu.gttsize=3072"

PRESERVE_PATHS=(
  /etc/fstab
  /etc/machine-id
  /etc/hostname
  /etc/ssh/ssh_host_*
)
