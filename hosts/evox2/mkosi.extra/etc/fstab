# evox2 persistent mutable state
#
# Keep /home outside the slot image so root A/B updates do not replace user data.
# Edit the source and filesystem type if your real layout is different.
#
# Examples:
#   UUID=<uuid>          /home  ext4   defaults,nofail,x-systemd.automount  0  2
#   PARTUUID=<partuuid>  /home  ext4   defaults,nofail,x-systemd.automount  0  2
#   LABEL=HOME           /home  btrfs  subvol=@home,compress=zstd,nofail,x-systemd.automount  0  0
LABEL=HOME /home ext4 defaults,nofail,x-systemd.automount 0 2
