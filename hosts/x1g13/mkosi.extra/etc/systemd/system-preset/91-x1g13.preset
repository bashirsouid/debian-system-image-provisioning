# Reload WiFi/audio/NPU drivers after rootfs firmware is available.
enable lnl-drivers-reload.service

# thinkfan requires a hand-written config before it can manage the fan curve.
# Disable it here so the service does not fail on first boot.
# To enable: configure /etc/thinkfan.yaml, then `systemctl enable --now thinkfan`.
disable thinkfan.service
