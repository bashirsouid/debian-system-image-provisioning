#!/usr/bin/env bash
# verify.sh — Post-boot verification for a running mkosi image.
#
# Run this INSIDE the booted VM (or on the baremetal host) to confirm
# everything is working before you flash the image to a production disk.
#
# Usage:
#   sudo ./verify.sh              # full verification (requires root)
#   sudo ./verify.sh --quick      # skip network probes, just check local state
#   sudo ./verify.sh --json       # output results as JSON
#
# What it checks:
#   • LUKS encryption — is the root filesystem encrypted?
#   • TPM enrollment  — is the LUKS volume bound to the TPM for auto-unlock?
#   • Credential store — are plaintext credentials present with correct perms?
#   • SSH server      — is sshd running with authorized keys?
#   • Tailscale VPN   — is it configured, connected, and reachable?
#   • Cloudflare      — is the tunnel configured and connected?
#   • System services — are there any failed systemd units?
#
# Exit codes:
#   0 — all checks passed
#   1 — one or more checks failed
#   2 — usage error

set -euo pipefail

# ── Colors ─────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ── Globals ────────────────────────────────────────────────────────────

QUICK=false
JSON=false
declare -A RESULT
declare -A DETAIL
CHECKS_RUN=0
CHECKS_PASS=0
CHECKS_FAIL=0
CHECKS_WARN=0
CHECKS_SKIP=0

# ── Helpers ────────────────────────────────────────────────────────────

say()  { printf '%s\n' "$*"; }
pass() { RESULT[$1]="pass"; DETAIL[$1]="$2"; CHECKS_PASS=$((CHECKS_PASS+1)); CHECKS_RUN=$((CHECKS_RUN+1)); printf "  ${GREEN}[PASS]${NC} %s — %s\n" "$1" "$2"; }
fail() { RESULT[$1]="fail"; DETAIL[$1]="$2"; CHECKS_FAIL=$((CHECKS_FAIL+1)); CHECKS_RUN=$((CHECKS_RUN+1)); printf "  ${RED}[FAIL]${NC} %s — %s\n" "$1" "$2"; }
warn() { RESULT[$1]="warn"; DETAIL[$1]="$2"; CHECKS_WARN=$((CHECKS_WARN+1)); CHECKS_RUN=$((CHECKS_RUN+1)); printf "  ${YELLOW}[WARN]${NC} %s — %s\n" "$1" "$2"; }
skip() { RESULT[$1]="skip"; DETAIL[$1]="$2"; CHECKS_SKIP=$((CHECKS_SKIP+1)); CHECKS_RUN=$((CHECKS_RUN+1)); printf "  ${CYAN}[skip]${NC} %s — %s\n" "$1" "$2"; }

# ── Parse args ─────────────────────────────────────────────────────────

while (( $# )); do
    case "$1" in
        --quick|-q) QUICK=true; shift ;;
        --json|-j)  JSON=true; shift ;;
        -h|--help)  sed -n '2,22p' "$0"; exit 0 ;;
        *)          echo "Unknown arg: $1" >&2; exit 2 ;;
    esac
done

if [[ "$(id -u)" -ne 0 ]]; then
    echo "ERROR: must be run as root. Try: sudo $0" >&2
    exit 2
fi

# ── Banner ─────────────────────────────────────────────────────────────

HOST="$(hostname)"
NOW="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
say ""
printf "${BOLD}═══════════════════════════════════════════════════════════${NC}\n"
printf "${BOLD}  Post-Boot Verification — %s${NC}\n" "$HOST"
printf "${BOLD}  %s${NC}\n" "$NOW"
printf "${BOLD}═══════════════════════════════════════════════════════════${NC}\n"
say ""

# ═══════════════════════════════════════════════════════════════════════
# 1. LUKS Encryption
# ═══════════════════════════════════════════════════════════════════════

say "── Disk Encryption ──────────────────────────────────────"

check_luks() {
    local crypt_dev
    crypt_dev="$(lsblk -rno NAME,TYPE,MOUNTPOINT 2>/dev/null \
        | awk '$2 == "crypt" && $3 == "/" {print $1; exit}')"

    if [[ -z "$crypt_dev" ]]; then
        fail luks "root filesystem is NOT on an encrypted volume"
        skip tpm2 "N/A (no LUKS)"
        return
    fi

    # Find the underlying partition
    local slave="" luks_dev=""
    slave="$(ls /sys/class/block/"${crypt_dev}"/slaves/ 2>/dev/null | head -1)"
    [[ -n "$slave" ]] && luks_dev="/dev/${slave}"

    if [[ -n "$luks_dev" ]] && cryptsetup isLuks "$luks_dev" 2>/dev/null; then
        pass luks "root encrypted (LUKS2) on ${luks_dev} via dm-crypt ${crypt_dev}"
    else
        pass luks "root is on dm-crypt ${crypt_dev} (backing device auto-detected)"
        luks_dev=""
    fi

    # TPM2 enrollment
    if [[ -z "$luks_dev" ]]; then
        skip tpm2 "cannot determine backing LUKS device"
        return
    fi

    if cryptsetup luksDump "$luks_dev" 2>/dev/null | grep -qi "tpm2"; then
        pass tpm2 "TPM2 auto-unlock enrolled on ${luks_dev}"
    else
        warn tpm2 "TPM2 NOT enrolled — run 'sudo ab-enroll-tpm' for auto-unlock"
    fi
}
check_luks
say ""

# ═══════════════════════════════════════════════════════════════════════
# 2. Credential Store
# ═══════════════════════════════════════════════════════════════════════

say "── Credential Store ─────────────────────────────────────"

check_credstore() {
    # Check that no encrypted credstore remains from old builds
    if [[ -d /etc/credstore.encrypted ]] && \
       compgen -G "/etc/credstore.encrypted/*" >/dev/null 2>&1; then
        warn credstore-legacy "legacy /etc/credstore.encrypted/ still has files — should be empty"
    else
        pass credstore-legacy "no legacy encrypted credstore (good)"
    fi

    # Check plaintext credstore exists
    if [[ ! -d /etc/credstore ]]; then
        skip credstore "no /etc/credstore/ directory"
        return
    fi

    local count=0 bad_perms=0
    for f in /etc/credstore/*; do
        [[ -f "$f" ]] || continue
        count=$((count + 1))
        local mode
        mode="$(stat -c '%a' "$f")"
        case "$mode" in
            400|600|640) ;;
            *) bad_perms=$((bad_perms + 1)) ;;
        esac
    done

    if (( count == 0 )); then
        skip credstore "no credentials in /etc/credstore/"
    elif (( bad_perms > 0 )); then
        fail credstore "${count} credential(s), but ${bad_perms} have weak permissions"
    else
        pass credstore "${count} credential(s) in /etc/credstore/ with correct permissions"
    fi

    # No master key should exist (we removed systemd-creds encryption)
    if [[ -f /var/lib/systemd/credential.secret ]]; then
        warn credstore-key "legacy /var/lib/systemd/credential.secret still exists — can be removed"
    fi
}
check_credstore
say ""

# ═══════════════════════════════════════════════════════════════════════
# 3. SSH
# ═══════════════════════════════════════════════════════════════════════

say "── SSH Server ───────────────────────────────────────────"

check_ssh() {
    if ! systemctl is-active --quiet ssh.service 2>/dev/null && \
       ! systemctl is-active --quiet sshd.service 2>/dev/null; then
        fail ssh "neither ssh.service nor sshd.service is active"
        return
    fi

    if ! sshd -t 2>/dev/null; then
        fail ssh "sshd -t rejected the config"
        return
    fi

    local port
    port="$(sshd -T 2>/dev/null | awk '/^port / {print $2; exit}')"
    port="${port:-22}"

    local keycount=0
    for f in /etc/ssh/authorized_keys.d/*; do
        [[ -f "$f" ]] || continue
        keycount=$((keycount + $(grep -cE '^(sk-|ssh-|ecdsa-)' "$f" 2>/dev/null || echo 0)))
    done

    if (( keycount == 0 )); then
        fail ssh "no authorized keys in /etc/ssh/authorized_keys.d/"
    else
        pass ssh "listening on :${port}, ${keycount} authorized key(s)"
    fi
}
check_ssh
say ""

# ═══════════════════════════════════════════════════════════════════════
# 4. Tailscale VPN
# ═══════════════════════════════════════════════════════════════════════

say "── Tailscale VPN ────────────────────────────────────────"

check_tailscale() {
    if ! command -v tailscale >/dev/null 2>&1; then
        skip tailscale "tailscale binary not installed"
        return
    fi

    if [[ ! -f /etc/credstore/tailscale-authkey ]]; then
        skip tailscale-cred "tailscale-authkey not provisioned"
    else
        pass tailscale-cred "tailscale-authkey present in credstore"
    fi

    if ! systemctl is-active --quiet tailscaled.service 2>/dev/null; then
        fail tailscale "tailscaled.service is not running"
        return
    fi

    if [[ "$QUICK" == true ]]; then
        skip tailscale "skipping network probe (--quick)"
        return
    fi

    local status
    status="$(tailscale status --json 2>/dev/null || echo '{}')"
    local backend_state
    backend_state="$(echo "$status" | jq -r '.BackendState // "unknown"' 2>/dev/null || echo "unknown")"

    case "$backend_state" in
        Running)
            local self_name
            self_name="$(echo "$status" | jq -r '.Self.HostName // "?"' 2>/dev/null || echo "?")"
            local self_ip
            self_ip="$(echo "$status" | jq -r '.Self.TailscaleIPs[0] // "?"' 2>/dev/null || echo "?")"
            pass tailscale "connected as ${self_name} (${self_ip})"
            ;;
        NeedsLogin)
            fail tailscale "needs login — auth key may be expired or revoked"
            ;;
        Stopped)
            fail tailscale "tailscaled running but backend is Stopped"
            ;;
        *)
            warn tailscale "backend state: ${backend_state}"
            ;;
    esac
}
check_tailscale
say ""

# ═══════════════════════════════════════════════════════════════════════
# 5. Cloudflare Tunnel
# ═══════════════════════════════════════════════════════════════════════

say "── Cloudflare Tunnel ────────────────────────────────────"

check_cloudflare() {
    if ! command -v cloudflared >/dev/null 2>&1; then
        skip cloudflare "cloudflared binary not installed"
        return
    fi

    if [[ ! -f /etc/credstore/cloudflared-token ]]; then
        skip cloudflare-cred "cloudflared-token not provisioned"
    else
        pass cloudflare-cred "cloudflared-token present in credstore"
    fi

    if ! systemctl is-active --quiet cloudflared.service 2>/dev/null; then
        fail cloudflare "cloudflared.service is not running"
        return
    fi

    if [[ "$QUICK" == true ]]; then
        skip cloudflare "skipping network probe (--quick)"
        return
    fi

    pass cloudflare "cloudflared.service is active"
}
check_cloudflare
say ""

# ═══════════════════════════════════════════════════════════════════════
# 6. Failed Systemd Units
# ═══════════════════════════════════════════════════════════════════════

say "── System Health ────────────────────────────────────────"

check_systemd() {
    local failed_units
    failed_units="$(systemctl --state=failed --no-legend --plain 2>/dev/null || true)"
    local count
    count="$(echo "$failed_units" | grep -c '.' || true)"

    if [[ -z "$failed_units" ]] || (( count == 0 )); then
        pass systemd "no failed units"
    else
        fail systemd "${count} failed unit(s): $(echo "$failed_units" | awk '{printf "%s ", $1}')"
    fi
}
check_systemd
say ""

# ═══════════════════════════════════════════════════════════════════════
# Summary
# ═══════════════════════════════════════════════════════════════════════

printf "${BOLD}═══════════════════════════════════════════════════════════${NC}\n"
printf "${BOLD}  Summary${NC}\n"
printf "${BOLD}═══════════════════════════════════════════════════════════${NC}\n"
say ""
printf "  ${GREEN}PASS: %d${NC}  ${RED}FAIL: %d${NC}  ${YELLOW}WARN: %d${NC}  ${CYAN}SKIP: %d${NC}  TOTAL: %d\n" \
    "$CHECKS_PASS" "$CHECKS_FAIL" "$CHECKS_WARN" "$CHECKS_SKIP" "$CHECKS_RUN"
say ""

if [[ "$JSON" == true ]]; then
    printf '{\n  "host": "%s",\n  "timestamp": "%s",\n  "summary": {\n    "pass": %d,\n    "fail": %d,\n    "warn": %d,\n    "skip": %d,\n    "total": %d\n  },\n  "results": {\n' \
        "$HOST" "$NOW" "$CHECKS_PASS" "$CHECKS_FAIL" "$CHECKS_WARN" "$CHECKS_SKIP" "$CHECKS_RUN"
    first=true
    for key in "${!RESULT[@]}"; do
        if [[ "$first" == true ]]; then first=false; else printf ',\n'; fi
        printf '    "%s": { "status": "%s", "detail": "%s" }' "$key" "${RESULT[$key]}" "${DETAIL[$key]}"
    done
    printf '\n  }\n}\n'
    exit $(( CHECKS_FAIL > 0 ? 1 : 0 ))
fi

if (( CHECKS_FAIL > 0 )); then
    printf "  ${RED}${BOLD}✗ VERIFICATION FAILED${NC} — do NOT flash this image to production.\n"
    say ""
    exit 1
elif (( CHECKS_WARN > 0 )); then
    printf "  ${YELLOW}${BOLD}⚠ VERIFICATION PASSED WITH WARNINGS${NC} — review warnings above.\n"
    say ""
    exit 0
else
    printf "  ${GREEN}${BOLD}✓ ALL CHECKS PASSED${NC} — image is ready for production.\n"
    say ""
    exit 0
fi
