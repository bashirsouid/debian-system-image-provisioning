#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=/usr/local/libexec/ab-common
source /usr/local/libexec/ab-common

ab_load_optional_env_file /usr/lib/os-release
ab_load_optional_env_file /etc/os-release
ab_load_optional_env_file "$AB_BUILD_INFO_PATH"
ab_load_optional_env_file "$AB_HEALTH_STATUS_PATH"

current_root="$(ab_current_root_source)"
current_label="$(ab_current_root_partlabel)"
current_uuid="$(ab_current_root_uuid)"

printf 'Current root source:   %s\n' "${current_root:-unknown}"
printf 'Current root label:    %s\n' "${current_label:-unknown}"
printf 'Current root UUID:     %s\n' "${current_uuid:-unknown}"
printf 'IMAGE_ID:              %s\n' "${IMAGE_ID:-${AB_IMAGE_ID:-unknown}}"
printf 'IMAGE_VERSION:         %s\n' "${IMAGE_VERSION:-${AB_IMAGE_VERSION:-unknown}}"

if [[ -n "${AB_BUILD_PROFILE:-}" || -n "${AB_BUILD_KERNEL_TRACK:-}" ]]; then
  echo
  echo 'Build metadata:'
  printf '  Profile:            %s\n' "${AB_BUILD_PROFILE:-unknown}"
  printf '  Host overlay:       %s\n' "${AB_BUILD_HOST_OVERLAY:-none}"
  printf '  Kernel track:       %s\n' "${AB_BUILD_KERNEL_TRACK:-unknown}"
  printf '  Build time:         %s\n' "${AB_BUILD_TIME_UTC:-unknown}"
  printf '  Git revision:       %s\n' "${AB_BUILD_GIT_REV:-unknown}"
  printf '  Host kernel args:   %s\n' "${AB_HOST_KERNEL_ARGS:-none}"
fi

if [[ -n "${AB_HEALTH_LAST_STATUS:-}" ]]; then
  echo
  echo 'Last boot health result:'
  printf '  Status:             %s\n' "${AB_HEALTH_LAST_STATUS:-unknown}"
  printf '  Time:               %s\n' "${AB_HEALTH_LAST_AT:-unknown}"
  printf '  Reason:             %s\n' "${AB_HEALTH_LAST_REASON:-none}"
fi

if command -v bootctl >/dev/null 2>&1; then
  echo
  echo 'bootctl list:'
  bootctl list --no-pager 2>/dev/null || true
fi

if command -v systemd-sysupdate >/dev/null 2>&1; then
  echo
  echo 'Installed sysupdate versions:'
  systemd-sysupdate list --offline 2>/dev/null || true
fi
