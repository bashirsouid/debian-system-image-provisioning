#!/usr/bin/env bash
# ab-enroll-tpm — Bind the LUKS root partition to the system's TPM2 chip.
#
# After running this once on baremetal, the machine will auto-unlock the
# encrypted root on every subsequent boot without prompting for a
# passphrase. If the drive is removed from this machine, it remains
# encrypted and unreadable.
#
# Usage:
#   sudo ab-enroll-tpm              # auto-detect LUKS partition + TPM
#   sudo ab-enroll-tpm /dev/sda3    # specify the LUKS partition explicitly
#   sudo ab-enroll-tpm --status     # check current enrollment status
#
# Requirements:
#   - Must be run as root on the booted target system
#   - A TPM2 device must be present (/dev/tpmrm0 or swtpm for QEMU)
#   - systemd-cryptenroll must be installed
#
# This is safe to run multiple times. If a TPM2 keyslot already exists,
# the script will report the current status and exit.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

info()  { printf "${CYAN}[ab-enroll-tpm]${NC} %s\n" "$*"; }
ok()    { printf "${GREEN}[ab-enroll-tpm]${NC} %s\n" "$*"; }
warn()  { printf "${YELLOW}[ab-enroll-tpm]${NC} %s\n" "$*" >&2; }
die()   { printf "${RED}[ab-enroll-tpm]${NC} %s\n" "$*" >&2; exit 1; }

# ── Helpers ────────────────────────────────────────────────────────────

find_luks_device() {
    # Look for the root filesystem's backing LUKS device.
    # Method 1: lsblk to find the crypt device under /
    local crypt_dev
    crypt_dev="$(lsblk -rno NAME,TYPE,MOUNTPOINT 2>/dev/null \
        | awk '$2 == "crypt" && $3 == "/" {print $1; exit}')"
    if [[ -n "$crypt_dev" ]]; then
        # Resolve the underlying partition from the dm-crypt mapping
        local slave
        slave="$(ls /sys/class/block/"${crypt_dev}"/slaves/ 2>/dev/null | head -1)"
        if [[ -n "$slave" ]]; then
            echo "/dev/${slave}"
            return 0
        fi
    fi

    # Method 2: scan all block devices for LUKS headers
    local dev
    for dev in /dev/sd?? /dev/nvme?n?p? /dev/vd??; do
        [[ -b "$dev" ]] || continue
        if cryptsetup isLuks "$dev" 2>/dev/null; then
            echo "$dev"
            return 0
        fi
    done

    return 1
}

check_tpm2_keyslot() {
    local dev="$1"
    # cryptsetup luksDump shows "tpm2" in the token section if enrolled
    if cryptsetup luksDump "$dev" 2>/dev/null | grep -qi "tpm2"; then
        return 0
    fi
    return 1
}

print_status() {
    local dev="$1"
    info "LUKS device: $dev"

    # Show LUKS token info
    info "--- LUKS Token Summary ---"
    cryptsetup luksDump "$dev" 2>/dev/null | grep -E '(Keyslots:|Token:|Type:)' | head -20
    echo

    if check_tpm2_keyslot "$dev"; then
        ok "✓ TPM2 keyslot is ENROLLED. This drive auto-unlocks on this machine."
    else
        warn "✗ TPM2 keyslot is NOT enrolled. Run 'sudo ab-enroll-tpm' to set it up."
    fi
}

# ── Preconditions ──────────────────────────────────────────────────────

if [[ "$(id -u)" -ne 0 ]]; then
    die "Must be run as root. Try: sudo ab-enroll-tpm"
fi

if ! command -v systemd-cryptenroll >/dev/null 2>&1; then
    die "systemd-cryptenroll not found. Install systemd-cryptenroll or systemd (>= 248)."
fi

if ! command -v cryptsetup >/dev/null 2>&1; then
    die "cryptsetup not found. Install cryptsetup."
fi

# ── Parse arguments ────────────────────────────────────────────────────

STATUS_ONLY=false
LUKS_DEV=""

while (( $# )); do
    case "$1" in
        --status|-s) STATUS_ONLY=true; shift ;;
        --help|-h)
            sed -n '2,19p' "$0"
            exit 0
            ;;
        /dev/*)
            LUKS_DEV="$1"; shift ;;
        *)
            die "Unknown argument: $1. See --help."
            ;;
    esac
done

# ── Find the LUKS device ──────────────────────────────────────────────

if [[ -z "$LUKS_DEV" ]]; then
    info "Auto-detecting LUKS partition..."
    if ! LUKS_DEV="$(find_luks_device)"; then
        die "No LUKS device found. Is the root partition encrypted?"
    fi
    info "Found: $LUKS_DEV"
fi

if ! cryptsetup isLuks "$LUKS_DEV" 2>/dev/null; then
    die "$LUKS_DEV is not a LUKS device."
fi

# ── Status check ───────────────────────────────────────────────────────

if [[ "$STATUS_ONLY" == true ]]; then
    print_status "$LUKS_DEV"
    exit 0
fi

# ── Check for TPM2 hardware ────────────────────────────────────────────

if [[ ! -c /dev/tpmrm0 ]]; then
    die "No TPM2 device found at /dev/tpmrm0.
    On baremetal, check BIOS settings to enable the TPM.
    In QEMU, ensure swtpm is running (run.sh handles this automatically)."
fi
info "TPM2 device found: /dev/tpmrm0"

# ── Check if already enrolled ──────────────────────────────────────────

if check_tpm2_keyslot "$LUKS_DEV"; then
    ok "TPM2 keyslot already exists on $LUKS_DEV."
    ok "This drive will auto-unlock on boot. Nothing to do."
    print_status "$LUKS_DEV"
    exit 0
fi

# ── Enroll ─────────────────────────────────────────────────────────────

info ""
info "This will bind $LUKS_DEV to this machine's TPM2 chip."
info "After enrollment, this drive will:"
info "  • Auto-unlock on every boot without a passphrase"
info "  • Be unreadable if moved to a different machine"
info ""
info "Your existing passphrase will still work as a fallback."
info ""
read -r -p "Proceed with TPM2 enrollment? [y/N] " confirm
case "$confirm" in
    [yY]|[yY][eE][sS]) ;;
    *) info "Aborted."; exit 0 ;;
esac

info "Enrolling TPM2 keyslot on $LUKS_DEV ..."
if systemd-cryptenroll --tpm2-device=auto "$LUKS_DEV"; then
    ok ""
    ok "═══════════════════════════════════════════════════════"
    ok "  ✓ TPM2 enrollment successful!"
    ok "  This drive will now auto-unlock on boot."
    ok "  Your passphrase still works as a manual fallback."
    ok "═══════════════════════════════════════════════════════"
else
    die "systemd-cryptenroll failed. Check the output above for details."
fi
