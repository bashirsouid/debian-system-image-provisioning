#!/bin/bash
# /usr/local/libexec/ab-monitor/load-creds-if-present
#
# ExecStartPre helper for ab-monitor.service / ab-heartbeat.service.
# Copies any of the well-known outbound-notification credentials that
# happen to be present in /etc/credstore/ into the unit's
# RuntimeDirectory ($CREDENTIALS_DIRECTORY), and silently skips the
# rest. Intentionally never returns non-zero on a missing or
# unreadable file — this is "best effort": if a notifier can't find its
# credential at $CREDENTIALS_DIRECTORY/<name>, the notifier will log
# and skip that channel rather than the whole monitor failing.

set -u

DEST="${CREDENTIALS_DIRECTORY:-}"
if [[ -z "$DEST" ]]; then
    echo "[load-creds] CREDENTIALS_DIRECTORY not set; refusing to run" >&2
    exit 0
fi

SRC=/etc/credstore

# Names this monitor / heartbeat stack knows about. Add new ones here
# the same day they are added as LoadCredential= in any unit.
CREDS=(
    mailjet_public_key
    mailjet_private_key
    pagerduty-routing-key
    healthchecks-ping-url
)

for cred in "${CREDS[@]}"; do
    src="$SRC/$cred"
    [[ -r "$src" ]] || continue
    if ! install -m 0400 "$src" "$DEST/$cred" 2>/dev/null; then
        rm -f "$DEST/$cred"
        echo "[load-creds] failed to copy $cred; skipping" >&2
        continue
    fi
done

exit 0
