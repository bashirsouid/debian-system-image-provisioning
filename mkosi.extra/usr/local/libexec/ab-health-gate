#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=/usr/local/libexec/ab-common
source /usr/local/libexec/ab-common

HEALTH_REASON=""

check_no_failed_units() {
  local failed_output
  failed_output="$(systemctl --failed --no-legend --plain 2>/dev/null || true)"
  if [[ -n "$failed_output" ]]; then
    HEALTH_REASON="failed-units"
    return 1
  fi
  return 0
}

run_health_hooks() {
  local hook
  [[ -d "$AB_HEALTH_HOOK_DIR" ]] || return 0
  while IFS= read -r -d '' hook; do
    [[ -x "$hook" ]] || continue
    if ! "$hook"; then
      HEALTH_REASON="hook:$(basename "$hook")"
      return 1
    fi
  done < <(find "$AB_HEALTH_HOOK_DIR" -maxdepth 1 -type f -perm /111 -print0 | sort -z)
  return 0
}

maybe_reboot_on_failure() {
  if ! ab_truthy "$AB_REBOOT_ON_HEALTH_FAILURE"; then
    return 0
  fi

  local delay
  delay="${AB_HEALTH_FAILURE_REBOOT_DELAY:-5}"
  if [[ "$delay" =~ ^[0-9]+$ ]] && (( delay > 0 )); then
    sleep "$delay"
  fi

  echo "Boot health gate failed; rebooting so the older retained version can win selection on the next boot" >&2
  systemctl reboot --force
}

main() {
  local now current_label current_uuid current_version current_id delay

  [[ $EUID -eq 0 ]] || ab_die "ab-health-gate must run as root"
  ab_load_optional_env_file "$AB_BUILD_INFO_PATH"

  delay="${AB_HEALTH_DELAY_SECS:-20}"
  if [[ "$delay" =~ ^[0-9]+$ ]] && (( delay > 0 )); then
    sleep "$delay"
  fi

  now="$(ab_now_utc)"
  current_label="$(ab_current_root_partlabel)"
  current_uuid="$(ab_current_root_uuid)"
  current_version="${IMAGE_VERSION:-${AB_IMAGE_VERSION:-}}"
  current_id="${IMAGE_ID:-${AB_IMAGE_ID:-}}"

  if ! check_no_failed_units || ! run_health_hooks; then
    ab_write_kv_file "$AB_HEALTH_STATUS_PATH" \
      AB_HEALTH_LAST_STATUS "unhealthy" \
      AB_HEALTH_LAST_AT "$now" \
      AB_HEALTH_LAST_REASON "$HEALTH_REASON" \
      AB_HEALTH_CURRENT_PARTLABEL "$current_label" \
      AB_HEALTH_CURRENT_UUID "$current_uuid" \
      AB_HEALTH_CURRENT_IMAGE_ID "$current_id" \
      AB_HEALTH_CURRENT_IMAGE_VERSION "$current_version"
    echo "Boot health gate failed: $HEALTH_REASON" >&2
    maybe_reboot_on_failure
    exit 1
  fi

  ab_write_kv_file "$AB_HEALTH_STATUS_PATH" \
    AB_HEALTH_LAST_STATUS "healthy" \
    AB_HEALTH_LAST_AT "$now" \
    AB_HEALTH_LAST_REASON "" \
    AB_HEALTH_CURRENT_PARTLABEL "$current_label" \
    AB_HEALTH_CURRENT_UUID "$current_uuid" \
    AB_HEALTH_CURRENT_IMAGE_ID "$current_id" \
    AB_HEALTH_CURRENT_IMAGE_VERSION "$current_version"
}

main "$@"
