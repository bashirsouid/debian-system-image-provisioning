#!/usr/bin/env bash
set -euo pipefail

stub=/run/systemd/resolve/stub-resolv.conf
fallback=/run/ab-dns-fallback-resolv.conf
probe_name="${AB_DNS_PROBE_NAME:-openai.com}"

write_fallback() {
    cat >"$fallback" <<'EOF'
# Managed by ab-dns-ensure. Used only when systemd-resolved is unhealthy.
nameserver 1.1.1.1
nameserver 8.8.8.8
options edns0 trust-ad
EOF
    ln -sfn "$fallback" /etc/resolv.conf
}

use_resolved() {
    ln -sfn "$stub" /etc/resolv.conf
    if command -v resolvectl >/dev/null 2>&1; then
        resolvectl flush-caches >/dev/null 2>&1 || true
    fi
}

resolved_healthy() {
    [[ -s "$stub" ]] || return 1
    command -v resolvectl >/dev/null 2>&1 || return 0
    resolvectl query "$probe_name" >/dev/null 2>&1
}

if resolved_healthy; then
    if [[ ! -L /etc/resolv.conf || "$(readlink /etc/resolv.conf)" != "$stub" ]]; then
        use_resolved
    fi
    exit 0
fi

if command -v systemctl >/dev/null 2>&1; then
    systemctl try-restart systemd-resolved.service >/dev/null 2>&1 || true
    sleep 2
fi

if resolved_healthy; then
    use_resolved
else
    write_fallback
fi
