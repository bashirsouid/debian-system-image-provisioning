#!/usr/bin/env bash
set -euo pipefail

AB_BUILD_INFO_PATH="${AB_BUILD_INFO_PATH:-/usr/local/share/ab-image-meta/build-info.env}"
AB_HEALTH_STATUS_PATH="${AB_HEALTH_STATUS_PATH:-/var/lib/ab-health/status.env}"
AB_HEALTH_HOOK_DIR="${AB_HEALTH_HOOK_DIR:-/usr/local/libexec/ab-health-check.d}"
AB_HEALTH_DELAY_SECS="${AB_HEALTH_DELAY_SECS:-20}"
AB_REBOOT_ON_HEALTH_FAILURE="${AB_REBOOT_ON_HEALTH_FAILURE:-no}"
AB_HEALTH_FAILURE_REBOOT_DELAY="${AB_HEALTH_FAILURE_REBOOT_DELAY:-5}"

ab_die() {
  echo "ERROR: $*" >&2
  exit 1
}

ab_now_utc() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

ab_truthy() {
  case "${1,,}" in
    1|y|yes|true|on)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

ab_load_optional_env_file() {
  local path="$1"
  if [[ -f "$path" ]]; then
    # shellcheck disable=SC1090
    source "$path"
  fi
}

ab_current_root_source() {
  findmnt -nro SOURCE / 2>/dev/null || true
}

ab_current_root_partlabel() {
  local src
  src="$(ab_current_root_source)"
  [[ -n "$src" ]] || return 0
  blkid -o value -s PARTLABEL "$src" 2>/dev/null || true
}

ab_current_root_uuid() {
  local src
  src="$(ab_current_root_source)"
  [[ -n "$src" ]] || return 0
  blkid -o value -s UUID "$src" 2>/dev/null || true
}

ab_write_kv_file() {
  local path="$1"
  shift
  local tmp dir
  dir="$(dirname "$path")"
  mkdir -p "$dir"
  tmp="$(mktemp "$dir/.abtmp.XXXXXX")"
  : > "$tmp"
  while [[ $# -gt 0 ]]; do
    printf '%s=%q\n' "$1" "${2-}" >> "$tmp"
    shift 2
  done
  chmod 0644 "$tmp"
  mv "$tmp" "$path"
}

ab_require_slot_conf() {
  local conf="/etc/ab-slot.conf"
  [[ -f "$conf" ]] || ab_die "$conf not found"
  # shellcheck disable=SC1090
  source "$conf"
}

ab_open_state_dir() {
  [[ -n "${AB_ESP_DEVICE:-}" ]] || ab_die "AB_ESP_DEVICE not set; run ab_require_slot_conf first"
  [[ -n "${AB_STATE_ESP_DIR:-}" ]] || ab_die "AB_STATE_ESP_DIR not set; run ab_require_slot_conf first"

  AB_ESP_MOUNTPOINT="$(findmnt -nro TARGET -S "$AB_ESP_DEVICE" | head -n1 || true)"
  AB_ESP_MOUNTED_BY_US=false

  if [[ -z "$AB_ESP_MOUNTPOINT" ]]; then
    AB_ESP_MOUNTPOINT="/run/ab-esp"
    mkdir -p "$AB_ESP_MOUNTPOINT"
    mount "$AB_ESP_DEVICE" "$AB_ESP_MOUNTPOINT"
    AB_ESP_MOUNTED_BY_US=true
  fi

  AB_STATE_DIR="$AB_ESP_MOUNTPOINT$AB_STATE_ESP_DIR"
  mkdir -p "$AB_STATE_DIR"
}

ab_close_state_dir() {
  if [[ "${AB_ESP_MOUNTED_BY_US:-false}" == true && -n "${AB_ESP_MOUNTPOINT:-}" ]]; then
    umount "$AB_ESP_MOUNTPOINT"
    AB_ESP_MOUNTED_BY_US=false
  fi
}

ab_load_state() {
  [[ -n "${AB_STATE_DIR:-}" ]] || ab_die "AB_STATE_DIR not set; run ab_open_state_dir first"
  local path="$AB_STATE_DIR/status.env"
  ab_load_optional_env_file "$path"
}

ab_save_state() {
  [[ -n "${AB_STATE_DIR:-}" ]] || ab_die "AB_STATE_DIR not set; run ab_open_state_dir first"
  local path="$AB_STATE_DIR/status.env"
  ab_write_kv_file "$path" \
    AB_STATE_VERSION "${AB_STATE_VERSION:-2}" \
    AB_SAVED_SLOT "${AB_SAVED_SLOT:-}" \
    AB_SAVED_ENTRY_ID "${AB_SAVED_ENTRY_ID:-}" \
    AB_PENDING_SLOT "${AB_PENDING_SLOT:-}" \
    AB_PENDING_ENTRY_ID "${AB_PENDING_ENTRY_ID:-}" \
    AB_PENDING_IMAGE_SHA256 "${AB_PENDING_IMAGE_SHA256:-}" \
    AB_PENDING_DEPLOYED_AT "${AB_PENDING_DEPLOYED_AT:-}" \
    AB_LAST_BOOT_SLOT "${AB_LAST_BOOT_SLOT:-}" \
    AB_LAST_BOOT_STATUS "${AB_LAST_BOOT_STATUS:-}" \
    AB_LAST_BOOT_AT "${AB_LAST_BOOT_AT:-}" \
    AB_LAST_GOOD_SLOT "${AB_LAST_GOOD_SLOT:-}" \
    AB_LAST_GOOD_IMAGE_SHA256 "${AB_LAST_GOOD_IMAGE_SHA256:-}" \
    AB_LAST_GOOD_AT "${AB_LAST_GOOD_AT:-}" \
    AB_LAST_BAD_SLOT "${AB_LAST_BAD_SLOT:-}" \
    AB_LAST_BAD_IMAGE_SHA256 "${AB_LAST_BAD_IMAGE_SHA256:-}" \
    AB_LAST_BAD_REASON "${AB_LAST_BAD_REASON:-}" \
    AB_LAST_BAD_AT "${AB_LAST_BAD_AT:-}" \
    AB_LAST_FALLBACK_FROM "${AB_LAST_FALLBACK_FROM:-}" \
    AB_LAST_FALLBACK_TO "${AB_LAST_FALLBACK_TO:-}" \
    AB_LAST_FALLBACK_AT "${AB_LAST_FALLBACK_AT:-}" \
    AB_LAST_PROMOTION_SLOT "${AB_LAST_PROMOTION_SLOT:-}" \
    AB_LAST_PROMOTION_MODE "${AB_LAST_PROMOTION_MODE:-}" \
    AB_LAST_PROMOTION_AT "${AB_LAST_PROMOTION_AT:-}" \
    AB_LAST_MANUAL_PROMOTION_REQUIRED_SLOT "${AB_LAST_MANUAL_PROMOTION_REQUIRED_SLOT:-}" \
    AB_LAST_MANUAL_PROMOTION_REQUIRED_AT "${AB_LAST_MANUAL_PROMOTION_REQUIRED_AT:-}"
}
