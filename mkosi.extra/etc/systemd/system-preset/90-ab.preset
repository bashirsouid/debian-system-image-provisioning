enable tailscale-up.service
enable tailscale-watchdog.timer
enable cloudflared.service
enable cloudflared-watchdog.timer
enable ab-user-provision.service
enable ab-monitor.timer
enable ab-heartbeat.timer
enable ssh.service
# Disable ssh.socket explicitly. Debian's openssh-server ships both
# ssh.service AND ssh.socket enabled by default, but they fight over
# port 22: the socket grabs the listen FD first, and when ssh.service
# tries to bind it sees EADDRINUSE and crash-loops. The journal then
# fills with "ssh.service: Failed with result 'exit-code'" entries
# every few seconds. We pick service-mode (one persistent sshd that
# we can override cleanly via /etc/ssh/sshd_config.d/) and disable
# socket-activation.
disable ssh.socket
enable nftables.service
enable systemd-resolved.service
enable systemd-timesyncd.service
enable systemd-oomd.service
enable ab-runtime-validate-firstboot.service
# Disable systemd-boot-update on the test/sysupdate path. It runs
# `bootctl update` against /boot, which on a USB ESP can take 60-90
# seconds (FAT32 + slow USB writes), and the live-test USB doesn't
# need its bootloader rewritten on every boot. Production sysupdate
# handles its own bootloader bookkeeping via the .transfer files.
disable systemd-boot-update.service
